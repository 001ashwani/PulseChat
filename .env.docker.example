# Docker environment variables - copy to .env.docker and customize

# Node Environment
NODE_ENV=production

# Server Port
PORT=5000

# MongoDB Configuration
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=secure_password_here
MONGO_URI=mongodb://admin:secure_password_here@mongodb:27017/pulsechat?authSource=admin

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_32_chars_minimum
JWT_EXPIRE=7d

# Client URL (for CORS)
CLIENT_URL=http://localhost

# Logging
LOG_LEVEL=info
